{
  "version": "0.5.0",
  "description": "A fast, batteries-included ASGI framework. The FastAPI alternative.",
  "source": [
    {
      "path": "src/fastware/",
      "language": "python"
    }
  ],
  "docs": "docs/",
  "output": "docs/_build/",
  "base_url": "https://fastware.smmh.dev",
  "root_files": [
    "docs/_README.md",
    "docs/_CLAUDE.md"
  ],
  "versions": [
    {
      "version": "0.5.0",
      "indexed": true
    }
  ],
  "locales": [
    {
      "code": "en",
      "label": "English",
      "default": true
    }
  ],
  "gen": {
    "exclude": [
      "src.fastware",
      "src.fastware.types",
      "src.fastware._assets"
    ]
  },
  "topology": {
    "slug": "fastware",
    "docs_base": "https://docs.smmh.dev",
    "posts_base": "https://blog.smmh.dev",
    "assembly": "smm-h/selfdoc-cache",
    "projects": {
      "wesktop": "https://docs.smmh.dev/wesktop",
      "rlsbl": "https://docs.smmh.dev/rlsbl",
      "selfdoc": "https://docs.smmh.dev/selfdoc",
      "strictcli": "https://docs.smmh.dev/strictcli"
    }
  },
  "deploy": {
    "provider": "cloudflare-pages",
    "project": "fastware"
  },
  "assembly": {
    "repo": "smm-h/selfdoc-cache"
  }
}
